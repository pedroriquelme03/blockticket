# Supabase — projeto blockticket
NEXT_PUBLIC_SUPABASE_URL=https://qqkpepixtqmiaqwqmbjq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloque_a_anon_ou_publishable_key

# Service role: SÓ no servidor. Pegue em Supabase > Project Settings > API.
# Usada para confirmar pagamento (simula o webhook do PSP). NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=coloque_a_service_role_key

# Tenant padrão da loja (single-tenant no MVP).
NEXT_PUBLIC_TENANT_SLUG=aquamania

# AbacatePay (gateway de pagamento). SÓ no servidor.
# API key: Dashboard > Integração > Criar chave (use Dev mode para testar).
ABACATEPAY_API_KEY=
# Secret do webhook que você define ao registrar a URL no dashboard.
ABACATEPAY_WEBHOOK_SECRET=
